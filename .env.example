# InfluxDB connection (see SETUP.md section 1)
# Use https:// if InfluxDB is on a remote host to protect the API token in transit
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-read-only-token-here
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=home_assistant

# Flux query filters (see SETUP.md section 2)
MEASUREMENT=http_listener_v2
FIELD=temperature
DEVICE_ID=gisebo-01
HOST_FILTER=61781446e5e9

# Cloudflare Pages (see SETUP.md section 3)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_PROJECT_NAME=temperature

# Public URL of the deployed site (used for OpenGraph absolute URLs)
# SITE_URL=https://temperatur.pages.dev

# Timeout, optional (see SETUP.md section 4)
# TIMEOUT_SECONDS=30
# DEPLOY_TIMEOUT_SECONDS=120
